    "print(f\"  Continuous branch shape : {shap_values[0].shape}\")\n",
    "print(f\"  Carrier branch shape    : {shap_values[1].shape}\")\n",
    "print(f\"  Airport branch shape    : {shap_values[2].shape}\")"
