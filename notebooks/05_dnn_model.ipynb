    "def make_callbacks(run_name='dnn_v1'):\n",
    "    \"\"\"\n",
    "    Create the standard training callbacks.\n",
    "\n",
    "    Parameters\n",
    "    ----------\n",
    "    run_name : str — used to name the checkpoint file and log directory\n",
    "\n",
    "    Returns\n",
